{
  "manifest_version": 3,
  "name": "TabNotes - Context Keeper",
  "version": "1.0.0",
  "description": "Save your working context before stepping away and resume instantly later.",
  "permissions": [
    "tabs",
    "storage",
    "windows",
    "tabGroups",
     "notifications",
     "alarms"
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Open TabNotes"
    }
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Save Context (Ctrl+Shift+Y)",
    "default_icon": {
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "48": "icons/icon48.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "host_permissions": [
    "<all_urls>"
  ]
}
